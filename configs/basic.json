{
  "run_name": "Basic - 50x1 Plurality",

  "geodata_path": "./data/chicago_precincts_vap_cvap.gpkg",

  "gerrychain_output_dir": "outputs/districts/chain_out",

  "population_column": "total_pop_20",
  "population_vap_column": "total_vap_20",
  "pop_of_interest_column": "asian_nhpi_vap_20",

  "chain_length": 1000,

  "num_subsamples": 5,

  "total_seats": 50,

  "epsilon":  0.05,

  "voting_configs": {
    "Plurality": { "tiebreak": "random" }
  },

  "district_configs": [
      { "num_districts": 50, "winners": 1 }
  ],

  "turnout": { "W": 0.5, "B": 0.5, "H": 0.5, "A": 0.5},

  "num_voters": 10000,

  "slate_to_candidates": {
    "W": ["W1", "W2", "W3"],
    "B": ["B1", "B2", "B3"],
    "H": ["H1", "H2", "H3"],
    "A": ["A1", "A2", "A3"]
  },

  "focal_group": "A",

  "cohesion_parameters": {
    "W": { "W": 0.4, "B": 0.15, "H": 0.15, "A": 0.3 },
    "B": { "W": 0.15, "B": 0.4, "H": 0.3, "A": 0.15 },
    "H": { "W": 0.3, "B": 0.15, "H": 0.4, "A": 0.15 },
    "A": { "W": 0.3, "B": 0.15, "H": 0.15, "A": 0.4 }
  },

  "alphas": {
    "W": { "W": 1, "B": 1, "H": 1, "A": 1 },
    "B": { "W": 1, "B": 1, "H": 1, "A": 1 },
    "H": { "W": 1, "B": 1, "H": 1, "A": 1 },
    "A": { "W": 1, "B": 1, "H": 1, "A": 1 }
  },

  "num_reps": 1,
  
  "seed": 42
}
