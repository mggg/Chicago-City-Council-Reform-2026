{
  "run_name": "Low POC Turnout",

  "geodata_path": "./data/chicago_precincts_vap_cvap.gpkg",

  "gerrychain_output_dir": "outputs/districts/chain_out",

  "population_column": "total_pop_20",

  "population_vap_column": "total_vap_20",

  "pop_of_interest_column": "asian_nhpi_vap_20",

  "chain_length": 10000,

  "num_subsamples": 50,

  "total_seats": 50,

  "epsilon": 0.05,

  "voting_configs": {
    "FastSTV": { "n_seats": 5, "tiebreak": "random" }
  },

  "voter_models": ["slate_pl", "slate_bt"],

  "district_configs": [
    { "num_districts": 10, "winners": 5 }
  ],

  "blocs": {
    "W-A": ["W", "A"],
    "B": ["B"],
    "H": ["H"]
  },

  "turnout": { "W-A": 0.4529, "B": 0.25, "H": 0.25 },

  "num_voters": 10000,

  "slate_to_candidates": {
    "W": ["W1", "W2", "W3", "W4"],
    "B": ["B1", "B2", "B3"],
    "H": ["H1", "H2", "H3"],
    "A": ["A1"]
  },

  "focal_group": "A",

  "cohesion_parameters": {
    "W-A": { "W": 0.35, "B": 0.15, "H": 0.15, "A": 0.35 },
    "B": { "W": 0.15, "B": 0.4, "H": 0.3, "A": 0.15 },
    "H": { "W": 0.3, "B": 0.15, "H": 0.4, "A": 0.15 }
  },

  "alphas": {
    "W-A": { "W": 1, "B": 1, "H": 1, "A": 1 },
    "B": { "W": 1, "B": 1, "H": 1, "A": 1 },
    "H": { "W": 1, "B": 1, "H": 1, "A": 1 }
  },

  "num_reps": 10,

  "seed": 42
}
