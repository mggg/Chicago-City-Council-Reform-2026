{
  "run_name": "50 X 1 PSMD - Larger Asian Districts (Optimized)",

  "geodata_path": "./data/chicago_precincts_vap_cvap.gpkg",

  "gerrychain_output_dir": "outputs/districts/chain_out",

  "population_column": "total_pop_20",

  "population_vap_column": "total_vap_20",

  "pop_of_interest_column": "asian_nhpi_vap_20",

  "chain_length": 10000,

  "num_subsamples": 50,

  "total_seats": 50,

  "optimize_for_bloc": "A",
  "optimize_threshold": 0.2,
  "burst_length": 100,

  "candidate_geometric_p": 0.2,

  "epsilon": 0.05,

  "voting_configs": {
    "IRV": { "tiebreak": "random" }
  },

  "voter_models": ["slate_pl", "slate_bt"],

  "district_configs": [
    { "num_districts": 50, "winners": 1 }
  ],

  "blocs": {
    "A": ["A"],
    "W": ["W"],
    "B": ["B"],
    "H": ["H"]
  },

  "turnout": { "A": 1, "W": 1, "B": 1, "H": 1 },

  "num_voters": 10000,

  "slate_to_candidates": {
    "W": ["W1", "W2", "W3", "W4"],
    "B": ["B1", "B2", "B3"],
    "H": ["H1", "H2", "H3"],
    "A": ["A1"]
  },

  "focal_group": "A",

  "cohesion_parameters": {
    "W": { "W": 0.70, "B": 0.15, "H": 0.05, "A": 0.10 },
    "B": { "W": 0.05, "B": 0.75, "H": 0.10, "A": 0.10 },
    "H": { "W": 0.15, "B": 0.05, "H": 0.75, "A": 0.05 },
    "A": { "W": 0.2, "B": 0.03, "H": 0.02, "A": 0.75 }
  },

  "alphas": {
    "A": { "W": 1, "B": 1, "H": 1, "A": 1 },
    "W": { "W": 1, "B": 1, "H": 1, "A": 1 },
    "B": { "W": 1, "B": 1, "H": 1, "A": 1 },
    "H": { "W": 1, "B": 1, "H": 1, "A": 1 }
  },

  "num_reps": 5,

  "seed": 42
}
